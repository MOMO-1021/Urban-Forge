---
// SpecializedAreas.astro
---

<section class="specialized-areas">
  <div class="container relative-z">
    <div class="section-header text-center">
      <h2>Our Specialized Expertise</h2>
      <p>Discover our most sought-after architectural metalwork services catering to high-end residential and commercial projects.</p>
    </div>
    
    <div class="areas-grid">
      <!-- Fireplace Screens -->
      <a href="/custom-fireplace-screens" class="area-card">
        <div class="card-content">
          <h3>Custom Fireplace Screens</h3>
          <p>Hand-forged heavy-duty safety mesh and precision fitment for any hearth.</p>
          <span class="explore-btn">Explore Gallery &rarr;</span>
        </div>
        <div class="card-bg"></div>
      </a>

      <!-- Metal Railings -->
      <a href="/custom-metal-railings-seattle" class="area-card">
        <div class="card-content">
          <h3>Custom Metal Railings Seattle</h3>
          <p>Code-compliant, master-crafted interior and exterior railings for the PNW.</p>
          <span class="explore-btn">View Local Projects &rarr;</span>
        </div>
        <div class="card-bg"></div>
      </a>

      <!-- Architectural Blacksmiths -->
      <a href="/architectural-blacksmiths-near-me" class="area-card">
        <div class="card-content">
          <h3>Architectural Blacksmiths Near Me</h3>
          <p>Experience true artistry. Genuine hand-forged metalwork from our local forge.</p>
          <span class="explore-btn">See The Craft &rarr;</span>
        </div>
        <div class="card-bg"></div>
      </a>
    </div>
  </div>
</section>

<style>
  .specialized-areas {
    padding: var(--spacing-xxl) 0;
    position: relative;
    background-color: var(--color-matte-black);
    background-image: linear-gradient(135deg, rgba(20,20,20,1) 0%, rgba(30,30,30,1) 100%);
    border-top: 2px solid var(--color-brushed-brass);
    border-bottom: 2px solid var(--color-brushed-brass);
    overflow: hidden;
  }
  
  /* Add a subtle glow behind the section */
  .specialized-areas::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 80%;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .relative-z {
    position: relative;
    z-index: 2;
  }
  
  .section-header {
    margin-bottom: var(--spacing-xl);
  }
  
  .section-header h2 {
    color: var(--color-brushed-brass);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: var(--spacing-sm);
  }
  
  .section-header p {
    color: var(--color-off-white);
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
    text-align: left;
    opacity: 0.9;
    line-height: 1.6;
  }
  
  .areas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-lg);
  }
  
  .area-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(212, 175, 55, 0.2);
    padding: var(--spacing-xl) var(--spacing-lg);
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }
  
  .card-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom right, transparent, rgba(212, 175, 55, 0.08));
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 1;
  }
  
  .card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  
  .area-card h3 {
    color: var(--color-off-white);
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-heading);
    transition: color 0.3s ease;
  }
  
  .area-card p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    margin-bottom: 2rem;
    flex-grow: 1;
    font-size: 1.05rem;
  }
  
  .explore-btn {
    color: var(--color-brushed-brass);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    transition: transform 0.3s ease;
  }
  
  /* Hover Effects */
  .area-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-brushed-brass);
    box-shadow: 0 15px 30px rgba(0,0,0,0.5), 0 0 20px rgba(212, 175, 55, 0.15);
  }
  
  .area-card:hover .card-bg {
    opacity: 1;
  }
  
  .area-card:hover h3 {
    color: var(--color-brushed-brass);
  }
  
  .area-card:hover .explore-btn {
    transform: translateX(5px);
  }
</style>
