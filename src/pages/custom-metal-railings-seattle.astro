---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import InquiryForm from '../components/InquiryForm.astro';

// Structured data for local business and service
const schemaData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Custom Metal Railings",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Urban Forge",
    "areaServed": {
      "@type": "City",
      "name": "Seattle"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Seattle"
  }
};
---

<Layout title="Custom Metal Railings Seattle | The Urban Forge" description="Hand-forged custom metal railings for Seattle area homes and businesses. Serving Bellevue, Mercer Island and greater Seattle for 15 years with architectural ironwork.">
  <Header />

  <!-- Hero Section -->
  <section class="location-hero">
    <div class="hero-overlay"></div>
    <div class="container relative-z text-center">
      <div class="trust-badge">EST. 2008 &mdash; Serving the greater Seattle area for over 15 years</div>
      <h1>Custom Metal Railings in Seattle, WA</h1>
      <p class="subtitle">Elevating Pacific Northwest architecture with bespoke, hand-forged ironwork and precision-engineered railings.</p>
      <a href="#quote" class="btn">Get a Quote for Your Project</a>
    </div>
  </section>

  <!-- Content & Gallery Grid -->
  <section class="container section">
    <div class="content-grid">
      <!-- Left Column: Copy -->
      <div class="local-copy">
        <h2>Uncompromising Quality for Seattle Homes</h2>
        <p>Whether you are designing a contemporary waterfront property on Mercer Island or restoring a classic Craftsman in Queen Anne, your staircase and balconies demand more than off-the-shelf solutions.</p>
        <p>At The Urban Forge, we specialize in designing, fabricating, and installing <strong>custom metal railings</strong> that meet Seattle's stringent building codes while delivering breathtaking aesthetic impact. Every baluster is cut, welded, and finished by master artisans right here in the Pacific Northwest.</p>
        
        <h3>Why Choose The Urban Forge?</h3>
        <ul class="features">
          <li><strong>Code Compliant:</strong> Fully versed in Washington State and Seattle municipal building codes for guardrails and handrails.</li>
          <li><strong>Weather-Resistant Finishes:</strong> Our proprietary powder coating and patinas are engineered to withstand the PNW marine environment.</li>
          <li><strong>Seamless Installation:</strong> We handle everything from the initial site measure to the final white-glove installation.</li>
        </ul>
      </div>

      <!-- Right Column: Local Gallery -->
      <div class="local-gallery">
        <div class="gallery-item">
          <!-- Placeholder Image -->
          <div class="img-box">Project Gallery: Bellevue Estate</div>
          <p class="caption">Custom modern brass & steel railing, Bellevue</p>
        </div>
        <div class="gallery-item">
          <div class="img-box">Project Gallery: Queen Anne</div>
          <p class="caption">Hand-forged exterior balcony guard, Queen Anne</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial Section -->
  <section class="bg-dark testimonial-section">
    <div class="container text-center">
      <h2 style="color: var(--color-brushed-brass); margin-bottom: var(--spacing-lg);">Hear from our Seattle Clients</h2>
      
      <div class="testimonial-grid">
        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <p class="quote">"We needed a custom interior railing that could serve as the center piece of our new build in Magnolia. The Urban Forge delivered a masterpiece that flawlessly blends industrial steel with warm wood. True artisans."</p>
          <p class="author">&mdash; Sarah J., Magnolia</p>
        </div>
        
        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <p class="quote">"Finding a local blacksmith who understands both structural engineering codes and high-end design is rare. They handled our exterior deck railings with incredible professionalism."</p>
          <p class="author">&mdash; Thomas R., Mercer Island</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Conversion Section with Form -->
  <section id="quote" class="conversion-section container">
    <div class="conversion-grid">
      <div class="conversion-text">
        <h2>Start Your Custom Project</h2>
        <p>Ready to commission a custom railing for your property? Fill out the form with details about your location and vision. Our design team will get back to you within 24 hours to schedule an initial consultation and site visit anywhere in the greater Seattle metro area.</p>
        <div class="contact-info" style="margin-top: var(--spacing-lg);">
          <p><strong>Our Local Forge:</strong><br/>123 Industrial Way, Suite A<br/>Metalworks District, Seattle, WA 98101</p>
        </div>
      </div>
      
      <div class="form-wrapper">
        <InquiryForm />
      </div>
    </div>
  </section>

  <footer class="bg-dark" style="padding: var(--spacing-lg) 0; text-align: center;">
     <p style="color: var(--color-off-white); margin: 0;">&copy; {new Date().getFullYear()} The Urban Forge. All rights reserved.</p>
  </footer>

  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</Layout>

<style>
  .location-hero {
    position: relative;
    padding: var(--spacing-xxl) 0;
    background-color: var(--color-charcoal);
    /* In a real project, this would be a background image of Seattle or a project */
    background-image: linear-gradient(to right, rgba(26,26,26,0.9), rgba(26,26,26,0.7));
    min-height: 50vh;
    display: flex;
    align-items: center;
    border-bottom: 2px solid var(--color-brushed-brass);
  }
  .hero-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: url('/images/texture-overlay.png') repeat; /* Placeholder texture */
    opacity: 0.1;
    z-index: 1;
  }
  .relative-z {
    position: relative;
    z-index: 2;
  }
  .text-center {
    text-align: center;
  }
  .location-hero h1 {
    color: var(--color-off-white);
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: var(--spacing-sm);
  }
  .subtitle {
    font-size: 1.25rem;
    color: #e0e0e0;
    max-width: 700px;
    margin: 0 auto var(--spacing-md);
  }
  .trust-badge {
    display: inline-block;
    color: var(--color-brushed-brass);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.85rem;
    font-family: var(--font-heading);
  }
  
  .content-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--spacing-xl);
    padding: var(--spacing-xl) 0;
  }
  .local-copy h2 {
    color: var(--color-matte-black);
    margin-bottom: 1.5rem;
    font-size: 2rem;
  }
  .local-copy p {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    color: #444;
  }
  .local-copy h3 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-family: var(--font-heading);
    color: var(--color-charcoal);
  }
  .features {
    list-style-type: none;
    padding: 0;
  }
  .features li {
    margin-bottom: 1rem;
    position: relative;
    padding-left: 1.5rem;
    line-height: 1.6;
  }
  .features li::before {
    content: '▪';
    color: var(--color-brushed-brass);
    position: absolute;
    left: 0;
    font-size: 1.2rem;
  }
  
  .local-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  .gallery-item {
    background: #f5f5f5;
    border: 1px solid #ddd;
    padding: 0.5rem;
  }
  .img-box {
    width: 100%;
    aspect-ratio: 16/9;
    background-color: #333;
    color: #aaa;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
  }
  .caption {
    font-size: 0.9rem;
    text-align: center;
    padding: 0.5rem 0;
    margin: 0;
    color: #666;
    font-style: italic;
  }
  
  .testimonial-section {
    padding: var(--spacing-xxl) 0;
  }
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    max-width: 1000px;
    margin: 0 auto;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    padding: var(--spacing-lg);
    text-align: left;
  }
  .stars {
    color: var(--color-brushed-brass);
    font-size: 1.2rem;
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }
  .quote {
    color: var(--color-off-white);
    font-size: 1.1rem;
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 1.5rem;
  }
  .author {
    color: var(--color-brushed-brass);
    font-weight: 600;
    font-family: var(--font-heading);
    margin: 0;
    font-size: 0.95rem;
  }
  
  .conversion-section {
    padding: var(--spacing-xxl) 0;
  }
  .conversion-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--spacing-xl);
    align-items: center;
  }
  .conversion-text h2 {
    color: var(--color-matte-black);
    margin-bottom: var(--spacing-md);
    font-size: 2.2rem;
  }
  .conversion-text p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #444;
  }
  .form-wrapper {
    background-color: var(--color-charcoal);
    padding: var(--spacing-md);
    border-radius: 4px;
  }
  
  @media (max-width: 768px) {
    .content-grid, .conversion-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
