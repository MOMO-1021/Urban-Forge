---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SpecializedAreas from '../components/SpecializedAreas.astro';
---

<Layout title="Custom Architectural Blacksmith" description="Bespoke metalwork and luxury architectural blacksmithing for high-end residential and commercial spaces.">
  <Header />
  
  <section class="hero-section">
    <div class="video-background">
      <!-- Replaced with client's actual video later -->
      <video autoplay muted loop playsinline>
        <!-- Placeholder, this would be a high-res locally hosted or CDN video -->
        <source src="/hero-video-placeholder.mp4" type="video/mp4" />
      </video>
      <div class="overlay"></div>
    </div>
    
    <div class="hero-content container">
      <h1>Generational Ironwork & Bespoke Architectural Metal.</h1>
      <p>Hand-forged legacy stairs, artisan fireplace surrounds, and custom metalwork for the discerning eye.</p>
      <div class="cta-group">
        <a href="/contact" class="btn">Book a Consultation</a>
        <a href="/portfolio" class="btn btn-secondary white-btn">View Portfolio</a>
      </div>
    </div>
  </section>

  <section class="section container">
    <div class="intro-grid">
      <div class="intro-text">
        <h2>Artisans of the Forge</h2>
        <p>With a 20-year local reputation, we have evolved from traditional welders into true artisans. Our work is not mass-produced; each piece—from grand spiral staircases to intricate fireplace screens—is a unique expression of durability and design.</p>
        <p>We partner with architects, interior designers, and discerning clients to bring visionary spaces to life through steel, brass, and aluminum craftsmanship.</p>
      </div>
      <div class="intro-image">
        <div class="video-container">
          <iframe 
            src="https://www.youtube.com/embed/VH5gkQGTNfw" 
            title="YouTube video player" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen>
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <SpecializedAreas />

  <section class="section process-section">
    <div class="container">
      <div class="process-header">
        <h2>The Forge Process</h2>
        <p>Traditional blacksmithing meets modern architecture. A visual journey from raw steel to hand-forged legacy.</p>
      </div>
      <div class="process-steps">
        <div class="step">
          <h3>01. Concept &amp; Engineering</h3>
          <p>Collaborating with architects to ensure structural integrity and code-compliant profiles.</p>
        </div>
        <div class="step">
          <h3>02. Hand-Forging</h3>
          <p>Our master artisans shape raw steel using traditional anvil and hammer techniques—authenticity a CNC machine cannot replicate.</p>
        </div>
        <div class="step">
          <h3>03. Custom Patinas</h3>
          <p>Applying hand-rubbed finishes, from oil-rubbed bronze to blackened steel, for lasting tonal depth.</p>
        </div>
        <div class="step">
          <h3>04. White-Glove Installation</h3>
          <p>Flawless on-site integration by the very artisans who forged the piece.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Add simple footer for visual completion -->
  <footer class="bg-dark" style="padding: var(--spacing-lg) 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.1);">
     <p style="color: var(--color-off-white); margin: 0;">&copy; {new Date().getFullYear()} The Urban Forge. All rights reserved.</p>
  </footer>
</Layout>

<style>
  .hero-section {
    position: relative;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xxl);
    overflow: hidden;
  }
  .video-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background-color: var(--color-matte-black);
  }
  .video-background video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(26, 26, 26, 0.85) 0%, rgba(26, 26, 26, 0.3) 100%); /* Premium gradient overlay */
  }
  .hero-content {
    position: relative;
    z-index: 1;
    color: var(--color-off-white);
    width: 100%;
  }
  .hero-content h1 {
    color: var(--color-off-white);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.15;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -1px;
    max-width: 900px;
  }
  .hero-content p {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    margin-bottom: 2.5rem;
    font-family: var(--font-body);
    opacity: 0.9;
    max-width: 750px;
    line-height: 1.6;
  }
  .cta-group {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }
  .white-btn {
    color: var(--color-off-white);
    border-color: var(--color-off-white);
  }
  .white-btn:hover {
    background-color: var(--color-off-white);
    color: var(--color-matte-black);
  }
  
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }
  .intro-image {
    width: 100%;
  }
  .video-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
    border: 1px solid var(--color-brushed-brass);
  }
  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  @media (max-width: 768px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }

  .process-section {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-matte-black);
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .process-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .process-header h2 {
    color: var(--color-brushed-brass);
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .process-header p {
    color: var(--color-off-white);
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
    opacity: 0.9;
  }
  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
  }
  .step {
    padding: var(--spacing-lg);
    background: rgba(255, 255, 255, 0.03);
    border-top: 2px solid var(--color-brushed-brass);
    transition: transform 0.3s ease;
  }
  .step:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.05);
  }
  .step h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-off-white);
    font-family: var(--font-heading);
  }
  .step p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
