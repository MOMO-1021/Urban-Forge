---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
// Sort posts by date
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---

<Layout title="Metalworking & Design Blog | Urban Forge">
  <Header />
  
  <section class="page-header bg-dark">
    <div class="container relative-z text-center">
      <h1>The Forge Journal</h1>
      <p class="subtitle">Insights on custom metal fabrication, design trends, and architectural hardware.</p>
    </div>
  </section>

  <main class="container">
    <div class="blog-grid">
      {sortedPosts.map(post => (
        <a href={`/blog/${post.id}`} class="blog-card">
          <div class="card-image" style={`background-image: url('${post.data.featuredImage}')`}></div>
          <div class="card-content">
            <span class="category">{post.data.category}</span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="read-more">Read Article &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </main>
  
  <footer class="bg-dark text-center" style="padding: var(--spacing-lg) 0;">
     <p style="color: var(--color-off-white); margin: 0;">&copy; {new Date().getFullYear()} Urban Forge. All rights reserved.</p>
  </footer>
</Layout>

<style>
  .page-header {
    padding: var(--spacing-xxl) 0;
    position: relative;
    border-bottom: 2px solid var(--color-brushed-brass);
    margin-bottom: var(--spacing-xl);
  }
  .page-header h1 {
    color: var(--color-brushed-brass);
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin-bottom: var(--spacing-sm);
  }
  .subtitle {
    font-size: 1.25rem;
    color: var(--color-off-white);
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xxl);
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #eaeaea;
    text-decoration: none;
    color: var(--color-matte-black);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.08);
  }
  .card-image {
    height: 200px;
    background-size: cover;
    background-position: center;
  }
  .card-content {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .category {
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--color-brushed-brass);
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  .card-content h2 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
    color: var(--color-matte-black);
    line-height: 1.3;
  }
  .card-content p {
    font-size: 0.95rem;
    color: #666;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }
  .read-more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-matte-black);
  }
</style>
