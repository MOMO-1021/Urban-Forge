---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import InquiryForm from '../components/InquiryForm.astro';
---

<Layout title="Contact & Inquiries">
  <Header />
  
  <section class="page-header" style="background-color: var(--color-charcoal); color: var(--color-off-white); text-align: center; padding: var(--spacing-xl) 0;">
    <div class="container">
      <h1 style="color: var(--color-brushed-brass);">Book a Consultation</h1>
      <p style="font-size: 1.25rem; max-width: 600px; margin: 0 auto;">Discuss your specific project requirements with our artisans.</p>
    </div>
  </section>

  <main class="container section">
    <div class="contact-grid">
      <div class="contact-info">
        <h2>Let's Build Something Extraordinary</h2>
        <p>Whether you're an architect specifying hardware for a commercial build or a homeowner looking for a custom staircase, our team is ready to bring your vision to life.</p>
        
        <div class="info-block" style="margin-top: var(--spacing-lg);">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem;">Our Forge</h3>
          <p>123 Industrial Way, Suite A<br/>Metalworks District, City 12345</p>
        </div>
        
        <div class="info-block">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem;">Hours</h3>
          <p>Mon - Fri: 8:00 AM - 5:00 PM<br/>Consultations by appointment only.</p>
        </div>
      </div>
      
      <div class="contact-form-container">
        <InquiryForm />
      </div>
    </div>
  </main>

  <footer class="bg-dark" style="padding: var(--spacing-lg) 0; text-align: center;">
     <p style="color: var(--color-off-white); margin: 0;">&copy; {new Date().getFullYear()} The Urban Forge. All rights reserved.</p>
  </footer>
</Layout>


<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--spacing-xl);
  }
  
  .info-block {
    margin-bottom: var(--spacing-md);
  }
  
  .contact-form-container {
    background-color: var(--color-charcoal);
    border-radius: 4px;
    overflow: hidden;
  }
  
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
