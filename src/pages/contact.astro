---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Contact & Inquiries">
  <Header />
  
  <section class="page-header" style="background-color: var(--color-charcoal); color: var(--color-off-white); text-align: center; padding: var(--spacing-xl) 0;">
    <div class="container">
      <h1 style="color: var(--color-brushed-brass);">Book a Consultation</h1>
      <p style="font-size: 1.25rem; max-width: 600px; margin: 0 auto;">Discuss your specific project requirements with our artisans.</p>
    </div>
  </section>

  <main class="container section">
    <div class="contact-grid">
      <div class="contact-info">
        <h2>Let's Build Something Extraordinary</h2>
        <p>Whether you're an architect specifying hardware for a commercial build or a homeowner looking for a custom staircase, our team is ready to bring your vision to life.</p>
        
        <div class="info-block" style="margin-top: var(--spacing-lg);">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem;">Our Forge</h3>
          <p>123 Industrial Way, Suite A<br/>Metalworks District, City 12345</p>
        </div>
        
        <div class="info-block">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem;">Hours</h3>
          <p>Mon - Fri: 8:00 AM - 5:00 PM<br/>Consultations by appointment only.</p>
        </div>
      </div>
      
      <div class="contact-form-container">
        <!-- Using a generic action that can hook into Netlify Forms or Formspree -->
        <form id="inquiry-form" class="custom-form" action="/success-placeholder" method="POST" enctype="multipart/form-data">
          
          <div class="form-group">
            <label for="name">Full Name *</label>
            <input type="text" id="name" name="name" required />
          </div>
          
          <div class="form-group">
            <label for="company">Company / Firm (Optional)</label>
            <input type="text" id="company" name="company" />
          </div>
          
          <div class="form-group">
            <label for="project-type">Project Type *</label>
            <select id="project-type" name="project-type" required>
              <option value="" disabled selected>Select a project type...</option>
              <option value="railings">Custom Railings / Staircases</option>
              <option value="gates">Architectural Gates</option>
              <option value="fireplaces">Fireplace Surrounds</option>
              <option value="furniture">Bespoke Furniture</option>
              <option value="other">Other Commercial/Residential Work</option>
            </select>
          </div>
          
          <!-- Conditional Fields Container -->
          <div id="conditional-fields" style="display: none; padding: 1rem; background-color: #f9f9f9; border-left: 3px solid var(--color-brushed-brass); margin-bottom: 1rem;">
            <p id="conditional-hint" style="font-size: 0.9em; color: var(--color-charcoal); margin-bottom: 0.5rem;"></p>
            <div class="form-group" style="margin-bottom: 0;">
              <label for="specific-details">Specific Requirements</label>
              <input type="text" id="specific-details" name="specific-details" placeholder="e.g. Dimensions, material preference..." />
            </div>
          </div>
          
          <div class="form-group">
            <label for="budget">Estimated Budget Range *</label>
            <select id="budget" name="budget" required>
              <option value="" disabled selected>Select a range...</option>
              <option value="under-10k">Under $10,000</option>
              <option value="10k-25k">$10,000 - $25,000</option>
              <option value="25k-50k">$25,000 - $50,000</option>
              <option value="50k-plus">$50,000+</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="timeline">Desired Timeline</label>
            <select id="timeline" name="timeline">
              <option value="asap">Immediate (Within 4 weeks)</option>
              <option value="1-3-months">1 - 3 Months</option>
              <option value="3-6-months">3 - 6 Months</option>
              <option value="planning">Just Planning / Concept Stage</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="inspiration">Upload Inspiration / Drawings (Max 5MB)</label>
            <input type="file" id="inspiration" name="inspiration" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.dwg,.dxf" />
            <small style="display: block; margin-top: 0.25rem; color: #666;">Accepted formats: PDF, Images, or CAD (DWG/DXF).</small>
          </div>
          
          <div class="form-group">
            <label for="message">Additional Project Details</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          
          <button type="submit" class="btn" style="width: 100%;">Submit Inquiry</button>
        </form>
      </div>
    </div>
  </main>

  <footer class="bg-dark" style="padding: var(--spacing-lg) 0; text-align: center;">
     <p style="color: var(--color-off-white); margin: 0;">&copy; {new Date().getFullYear()} The Urban Forge. All rights reserved.</p>
  </footer>
</Layout>

<script>
  // Client-side logic for the contact form
  document.addEventListener('DOMContentLoaded', () => {
    const projectTypeSelect = document.getElementById('project-type');
    const conditionalFields = document.getElementById('conditional-fields');
    const conditionalHint = document.getElementById('conditional-hint');
    
    // Check URL parameters to pre-select service if coming from Services page
    const urlParams = new URLSearchParams(window.location.search);
    const serviceParam = urlParams.get('service');
    if (serviceParam && projectTypeSelect) {
      projectTypeSelect.value = serviceParam;
      updateConditionalLogic(serviceParam);
    }
    
    if (projectTypeSelect) {
      projectTypeSelect.addEventListener('change', (e) => {
        updateConditionalLogic(e.target.value);
      });
    }
    
    function updateConditionalLogic(val) {
      if(!conditionalFields || !conditionalHint) return;
      
      conditionalFields.style.display = 'block';
      
      switch(val) {
        case 'railings':
          conditionalHint.textContent = 'For railings, please specify linear footage and if it is for stairs or flat balconies.';
          break;
        case 'gates':
          conditionalHint.textContent = 'For gates, please specify driveway width and if automation is required.';
          break;
        case 'fireplaces':
          conditionalHint.textContent = 'For fireplaces, please provide the dimensions of the firebox opening.';
          break;
        case 'furniture':
          conditionalHint.textContent = 'For furniture, let us know if you want mixed materials (glass/wood insert).';
          break;
        default:
          conditionalFields.style.display = 'none';
      }
    }
  });
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--spacing-xl);
  }
  
  .info-block {
    margin-bottom: var(--spacing-md);
  }
  
  .contact-form-container {
    background: #fff;
    padding: var(--spacing-lg);
    border: 1px solid #ddd;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }
  
  .form-group {
    margin-bottom: 1.5rem;
  }
  
  label {
    display: block;
    margin-bottom: 0.5rem;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-charcoal);
  }
  
  input[type="text"],
  input[type="email"],
  select,
  textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ccc;
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }
  
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-brushed-brass);
  }
  
  input[type="file"] {
    font-family: var(--font-body);
  }
  
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
