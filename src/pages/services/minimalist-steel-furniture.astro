---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Minimalist Steel Furniture Custom | Urban Forge">
  <Header />
  <main class="container service-detail">
    <div class="breadcrumb">
      <a href="/services">Services</a> &gt; <span>Steel Furniture</span>
    </div>
    <h1>Custom Minimalist Steel Furniture</h1>
    <img src="/images/minimalist_steel_furniture.png" alt="Minimalist Steel Furniture" class="hero-image" />
    <div class="content-body">
      <h2>Desks, Tables, and Shelving</h2>
      <p>Our custom steel furniture combines raw industrial strength with minimalist design. We create bespoke desks, dining tables, shelving units, and bed frames.</p>
      <h3>Finishes & Pricing</h3>
      <p>Choose from durable powder-coated finishes or natural patinas. Lead times and pricing vary based on complexity, but we are transparent about the costs of custom metal fabrication.</p>
    </div>
  </main>
</Layout>
<style>
  .service-detail { padding: var(--spacing-xl) 0; max-width: 800px; }
  .breadcrumb { font-size: 0.9rem; color: #666; margin-bottom: var(--spacing-md); }
  h1 { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: var(--spacing-lg); color: var(--color-matte-black); }
  .hero-image { width: 100%; border: 2px solid var(--color-brushed-brass); margin-bottom: var(--spacing-xl); }
  .content-body h2, .content-body h3 { color: var(--color-matte-black); margin-top: var(--spacing-lg); }
  .content-body p { font-size: 1.1rem; line-height: 1.6; color: #444; }
</style>
