---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ServiceCTA from '../../components/ServiceCTA.astro';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Blacksmith",
  "name": "Urban Forge",
  "description": "Master architectural blacksmiths serving New York City.",
  "areaServed": ["Manhattan", "Brooklyn", "Queens", "Staten Island", "Bronx", "Westchester", "Long Island"]
};
---

<Layout title="Architectural Blacksmiths Near Me | New York | Urban Forge">
  <Header />
  
  <main class="container service-detail">
    <div class="breadcrumb">
      <a href="/services">Services</a> &gt; <span>Architectural Blacksmiths</span>
    </div>
    
    <h1>Architectural Blacksmiths Near Me in New York</h1>
    
    <img src="/images/architectural_blacksmiths.png" alt="Architectural Blacksmith NYC" class="hero-image" />
    
    <div class="content-body">
      <h2>Bespoke Architectural Blacksmithing & Artistry</h2>
      <p>As premier <strong>architectural blacksmiths</strong>, Urban Forge bridges the gap between historic hand-forging techniques and modern structural engineering. Every project we undertake is forged by hand on our anvils, heated to over 2,000°F in our custom gas and coal forges, and shaped by our master blacksmiths. Unlike automated CNC milling or generic welding shops, hand-forging introduces subtle, unique variations and rich textures into the metal. This organic character cannot be mass-produced, making each piece a lasting work of functional art.</p>
      
      <h3>Our Forging Capabilities & Processes</h3>
      <p>From our fully equipped local metalworks, we provide complete blacksmithing services for high-end residential estates, commercial lobbies, and historical restorations:</p>
      <ul>
        <li><strong>Hand-Hammered Scrollwork:</strong> Intricate, flowing details for custom grilles, driveway gates, and ornamental stair balusters shaped using traditional hammers and swage blocks.</li>
        <li><strong>Bespoke Architectural Hardware:</strong> Custom-designed strap hinges, pull handles, latches, and registers forged to match specific architectural periods.</li>
        <li><strong>Structural Joinery:</strong> Utilizing traditional joinery methods such as mortise-and-tenon joints, hot-punched holes, and hand-driven rivets for structural integrity and timeless historical aesthetics.</li>
        <li><strong>Blacksmithing Restoration:</strong> Recreating missing or damaged ironwork details for historic buildings using period-correct alloys and techniques.</li>
      </ul>
      
      <h3>NYC Historic Landmarks Preservation</h3>
      <p>Working on properties in historic districts—such as Brooklyn Heights, Greenwich Village, or Park Slope—requires deep respect for architectural preservation. We collaborate closely with architects and the NYC Landmarks Preservation Commission (LPC) to replicate historic configurations exactly. Our blacksmiths analyze existing wrought iron gates, window grilles, and railings to match original profiles, dimensions, and hand-applied finishes, ensuring seamless approval and compliance.</p>
      
      <h3>Engineering & Material Certification</h3>
      <p>While our craft is rooted in tradition, our structural works are engineered for the modern world. We work alongside licensed structural engineers to certify the load ratings of our hand-forged assemblies. Whether we are forging heavy structural brackets, floating staircase frames, or security gates, we provide complete welding certifications and material reports to satisfy local building codes and inspection guidelines.</p>

      <blockquote class="testimonial">
        "Urban Forge designed a custom wrought iron gate for our brownstone that perfectly matched the historic neighborhood. True artisans!"<br>
        <strong>- Sarah T., Brooklyn, NY</strong>
      </blockquote>

      <div class="map-container">
        <h3>Visit Our Metalworks</h3>
        <p>123 Broadway, New York, NY 10001</p>
        <iframe src="https://maps.google.com/maps?q=123%20Broadway,%20New%20York,%20NY%2010001&t=&z=15&ie=UTF8&iwloc=&output=embed" width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
      <div class="architect-cta" style="background: #f9f9f9; border-left: 4px solid var(--color-brushed-brass); padding: var(--spacing-md); margin: var(--spacing-xl) 0; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--spacing-md);">
        <div>
          <h4 style="margin: 0 0 0.5rem 0; color: var(--color-matte-black);">Specifying this for a project?</h4>
          <p style="margin: 0; font-size: 0.95rem; color: #555;">Download structural profiles, CAD details, and technical cut-sheets.</p>
        </div>
        <a href="/architects" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem; border-color: var(--color-brushed-brass); color: var(--color-brushed-brass);">Get CAD Specs (.ZIP)</a>
      </div>

      <ServiceCTA title="Looking for a Metal Fabricator?" buttonText="Contact Our Team" />
    </div>
  </main>
  
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</Layout>

<style>
  .service-detail {
    padding-block: var(--spacing-xl);
    max-width: 800px;
  }
  .breadcrumb {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: var(--spacing-md);
  }
  .breadcrumb a {
    color: var(--color-brushed-brass);
  }
  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-lg);
    color: var(--color-matte-black);
  }
  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 4px;
    margin-bottom: var(--spacing-xl);
    border: 2px solid var(--color-brushed-brass);
  }
  .content-body h2, .content-body h3 {
    color: var(--color-matte-black);
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }
  .content-body p, .content-body ul {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #444;
    margin-bottom: var(--spacing-md);
  }
  .content-body ul {
    padding-left: 20px;
  }
  .content-body li {
    margin-bottom: 0.5rem;
  }
  .testimonial {
    font-style: italic;
    background: #f4f4f4;
    padding: 1.5rem;
    border-left: 4px solid var(--color-brushed-brass);
    margin: 2rem 0;
  }
  .map-container {
    margin: 3rem 0;
  }
</style>
