---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Steel Staircase Fabricator New York | Urban Forge">
  <Header />
  <main class="container service-detail">
    <div class="breadcrumb">
      <a href="/services">Services</a> &gt; <span>Steel Staircases</span>
    </div>
    <h1>Steel Staircase Fabricator in New York</h1>
    <img src="/images/steel_staircase.png" alt="Steel Staircase Fabricator" class="hero-image" />
    <div class="content-body">
      <h2>Floating, Spiral, and Industrial Stairs</h2>
      <p>We are NYC's premier steel staircase fabricators. Whether you need a minimalist floating staircase for a Manhattan penthouse or a heavy-duty industrial spiral stair, we handle structural steel engineering and fabrication.</p>
      <h3>Structural vs. Light Gauge</h3>
      <p>We work closely with engineers and architects to determine the right materials for the load requirements, prioritizing safety and aesthetic design.</p>
    </div>
  </main>
</Layout>
<style>
  .service-detail { padding: var(--spacing-xl) 0; max-width: 800px; }
  .breadcrumb { font-size: 0.9rem; color: #666; margin-bottom: var(--spacing-md); }
  h1 { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: var(--spacing-lg); color: var(--color-matte-black); }
  .hero-image { width: 100%; border: 2px solid var(--color-brushed-brass); margin-bottom: var(--spacing-xl); }
  .content-body h2, .content-body h3 { color: var(--color-matte-black); margin-top: var(--spacing-lg); }
  .content-body p { font-size: 1.1rem; line-height: 1.6; color: #444; }
</style>
